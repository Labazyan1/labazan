# Заголовки безопасности
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS — только по HTTPS (сертификат Beget/Certbot)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  # CSP: 'unsafe-inline' в script/style нужен под inline-скрипты Astro и заинлайненные стили;
  # шрифты — Google Fonts; заявка уходит POST на свой /api; виджет-бот шлёт fetch на
  # bot.labazan.ru (РФ-ВМ) — поэтому он в connect-src.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://bot.labazan.ru; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'"
</IfModule>

# Запрет прямого доступа к файлу с секретами бота
<FilesMatch "lead-config.*\.php$">
  Require all denied
</FilesMatch>

# 301-редиректы удалённых услуг → на ближайшую релевантную страницу.
# Без #-фрагментов (краулеры их игнорируют); ведём на существующую услугу,
# чтобы передать ссылочный вес, а не на общий хаб, где это возможно.
<IfModule mod_alias.c>
  RedirectMatch 301 ^/uslugi/kontent-plan/?$ /uslugi/vedenie-socsetej/
  RedirectMatch 301 ^/uslugi/reels-shorts/?$ /uslugi/video-reklama/
  RedirectMatch 301 ^/uslugi/audit-sajta/?$ /uslugi/seo-prodvizhenie/
  RedirectMatch 301 ^/uslugi/kartochki-marketplejsy/?$ /uslugi/
  RedirectMatch 301 ^/uslugi/analitika-dannyh/?$ /uslugi/
</IfModule>

# Сжатие
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Кеш статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
</IfModule>
