---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title="Блог студии Лабазан — про сайты, SEO и рекламу" description="Разбираем разработку сайтов, SEO, GEO/AEO и рекламу простым языком. Без воды и продающих лозунгов." path="/blog">
  <section class="page-hero">
    <div class="hero-grid"></div>
    <div class="wrap">
      <p class="breadcrumb"><a href="/">Главная</a> / Блог</p>
      <h1>Блог</h1>
      <p class="lead">Разбираем сайты, продвижение и рекламу простым языком. Пишем то, что помогает принимать решения, а не продаёт в лоб.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="post-list">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.id}`}>
            <span class="meta">{post.data.tag} · {fmt(post.data.date)}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="more">Читать →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
