---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title={post.data.metaTitle ?? `${post.data.title} — блог Лабазан`} description={post.data.description} path={`/blog/${post.id}`}>
  <section class="page-hero">
    <div class="hero-grid"></div>
    <div class="wrap">
      <p class="breadcrumb"><a href="/">Главная</a> / <a href="/blog">Блог</a> / {post.data.tag}</p>
      <h1 style="font-size:clamp(28px,4.4vw,44px)">{post.data.title}</h1>
      <p class="lead" style="margin-top:6px">{post.data.tag} · {fmt(post.data.date)}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <article class="prose" style="margin:0 auto">
        <Content />
      </article>
    </div>
  </section>
</Base>
