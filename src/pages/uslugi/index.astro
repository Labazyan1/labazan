---
import Base from '../../layouts/Base.astro';
import ContactForm from '../../components/ContactForm.astro';
import { categories } from '../../data/categories';

const meta = {
  title: 'Услуги: сайты, дизайн, реклама, SEO, SMM, видео | Лабазан',
  description:
    'Веб-разработка, дизайн, реклама и трафик, SEO, SMM, видео и маркетплейсы Wildberries и Ozon. Семь направлений с подпунктами, смета — до старта.',
};
---
<Base title={meta.title} description={meta.description} path="/uslugi">
  <section class="page-hero">
    <div class="hero-grid"></div>
    <div class="wrap">
      <p class="breadcrumb"><a href="/">Главная</a> / Услуги</p>
      <h1>Все услуги по направлениям</h1>
      <p class="lead">Собрали, что делаем, по семи направлениям с подпунктами — чтобы вы быстро нашли нужное. По любой позиции считаем смету до старта и фиксируем срок в договоре.</p>
      <nav class="hub-nav" aria-label="Направления">
        {categories.map((c) => (
          <a href={`#${c.slug}`}><span class="hub-nav-num">{c.num}</span>{c.label}</a>
        ))}
      </nav>
    </div>
  </section>

  {categories.map((c) => (
    <section class="section" id={c.slug}>
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">{c.num} · направление</span>
          <h2>{c.label}</h2>
          <p>{c.blurb}</p>
        </div>
        <div class="hub-grid">
          {c.items.map((it) => (
            it.slug ? (
              <a class="hub-item" href={`/uslugi/${it.slug}`}>
                <span class="hub-h">{it.label}<span class="arrow">→</span></span>
                <span class="hub-note">{it.note}</span>
              </a>
            ) : (
              <a class="hub-item hub-item--stub" href="/#contact">
                <span class="hub-h">{it.label}<span class="hub-tag">по запросу</span></span>
                <span class="hub-note">{it.note}</span>
              </a>
            )
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section" id="contact">
    <div class="wrap">
      <div class="cta-wrap reveal">
        <div>
          <h2>Не нашли нужное или сомневаетесь? Спросите.</h2>
          <p>Опишите задачу — подскажем, какая услуга подходит, посчитаем смету и срок. Бесплатно и без обязательств.</p>
        </div>
        <ContactForm compact={true} />
      </div>
    </div>
  </section>
</Base>
