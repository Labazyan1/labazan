---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';

const title = 'Калькулятор себестоимости заказа — как реклама удешевляет каждый заказ | Лабазан';
const description =
  'Посчитайте полную себестоимость заказа с учётом аренды и зарплат и увидьте, как дешёвые заказы с рекламы снижают её для всех заказов. Бесплатный калькулятор от студии Лабазан.';
---
<Base title={title} description={description} path="lead/stoimost-lida">
  <section class="calc-page">
    <div class="calc-wrap">
      <p class="kick">калькулятор · себестоимость заказа</p>
      <h1 class="h1">Как реклама <em>удешевляет</em> каждый ваш заказ</h1>
      <p class="lead">Аренда и зарплаты крутятся каждый месяц, придёт клиент или нет. Чем меньше заказов, тем
        дороже вам каждый. Подставьте свои цифры и посмотрите, что делают с себестоимостью дешёвые заказы с рекламы.</p>

      <div class="card">
        <div class="ctitle">сейчас</div>
        <div class="row"><label for="fixed">Постоянные расходы, ₽/мес</label>
          <div class="field"><input id="fixed" inputmode="numeric" value="200 000" aria-label="Постоянные расходы в месяц"><span class="cur">₽</span></div></div>
        <div class="row"><label for="cur">Заказов в месяц</label>
          <div class="field"><input id="cur" inputmode="numeric" value="20" aria-label="Заказов в месяц сейчас"><span class="cur">шт</span></div></div>
        <div class="mini"><span>Себестоимость одного заказа</span><span class="v" id="cplNow">10 000 ₽</span></div>
      </div>

      <div class="card">
        <div class="ctitle">добавляем <b>рекламу</b></div>
        <div class="row"><label for="ad">Рекламный бюджет, ₽/мес</label>
          <div class="field"><input id="ad" inputmode="numeric" value="40 000" aria-label="Рекламный бюджет в месяц"><span class="cur">₽</span></div></div>
        <div class="row"><label for="paid">Заказов с рекламы в месяц</label>
          <div class="field"><input id="paid" inputmode="numeric" value="20" aria-label="Заказов с рекламы в месяц"><span class="cur">шт</span></div></div>
        <div class="mini"><span>Один заказ с рекламы обошёлся в</span><span class="v" id="cppaid">2 000 ₽</span></div>
      </div>

      <div class="result">
        <div class="rlbl">себестоимость заказа</div>
        <div class="ba">
          <div class="col was"><span class="clbl">было</span><span class="n" id="was">10 000</span><span class="u">₽</span></div>
          <span class="arrow" aria-hidden="true">→</span>
          <div class="col now"><span class="clbl">стало</span><span class="n" id="now">6 000</span><span class="u">₽ за заказ</span></div>
        </div>
        <div class="drop"><span id="dropText">дешевле на </span><b id="dropv">40%</b></div>
      </div>

      <p class="note">Дешёвые заказы с рекламы <b>размазывают ваш фикс на больше заказов</b>, и каждый заказ, даже
        старый, обходится дешевле. Реклама не добавляет новых огромных расходов, она догружает то, за что вы уже
        платите. Работает, пока есть свободная ёмкость под новые заказы.</p>

      <a class="cta" href={site.telegram} rel="noopener">Посчитаю по вашим цифрам и покажу, где взять дешёвые заказы</a>
      <p class="cta-sub">Напишите в Telegram слово <b>САЙТ</b>, разберу ваш случай без обязательств.</p>
    </div>
  </section>
</Base>

<style>
  .calc-page{
    --ink:#0B0E12; --ink2:#12161C; --line:#252D38; --text:#F2F4F7; --muted:#8B94A0; --muted2:#5A6470; --accent:#FF5A1F; --ok:#3ED598;
    --mono:'JetBrains Mono',ui-monospace,monospace; --sans:'Golos Text',system-ui,sans-serif;
    background:var(--ink); color:var(--text); padding:52px 18px 72px; display:flex; justify-content:center;
  }
  .calc-wrap{width:100%; max-width:520px; display:flex; flex-direction:column; gap:16px}
  .kick{font-family:var(--mono);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent)}
  .h1{font-family:var(--sans);font-weight:600;font-size:clamp(26px,6.5vw,36px);line-height:1.06;letter-spacing:-.02em}
  .h1 em{color:var(--accent);font-style:normal}
  .lead{font-size:15px;line-height:1.5;color:var(--muted);max-width:52ch}

  .card{background:var(--ink2);border:1px solid var(--line);border-radius:15px;padding:16px 16px 18px;display:flex;flex-direction:column;gap:12px}
  .ctitle{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted2)}
  .ctitle b{color:var(--accent);font-weight:700}
  .row{display:flex;flex-direction:column;gap:5px}
  .row label{font-family:var(--mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
  .field{display:flex;align-items:center;gap:8px;background:var(--ink);border:1px solid var(--line);border-radius:9px;padding:11px 13px}
  .field:focus-within{border-color:var(--accent)}
  .field input{flex:1;min-width:0;background:transparent;border:0;outline:0;color:var(--text);font-family:var(--mono);font-weight:700;font-size:19px}
  .field .cur{font-family:var(--mono);font-size:14px;color:var(--muted2)}
  .mini{display:flex;justify-content:space-between;align-items:baseline;font-size:13px;color:var(--muted);padding-top:6px;border-top:1px dashed var(--line)}
  .mini .v{font-family:var(--mono);font-weight:700;font-size:16px;color:var(--text)}

  .result{background:rgba(255,90,31,.06);border:1px solid rgba(255,90,31,.5);border-radius:15px;padding:20px 16px}
  .result .rlbl{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);text-align:center;margin-bottom:12px}
  .ba{display:flex;align-items:center;justify-content:center;gap:16px}
  .ba .col{display:flex;flex-direction:column;align-items:center;gap:2px}
  .ba .clbl{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted2)}
  .ba .n{font-family:var(--mono);font-weight:800;letter-spacing:-.02em;line-height:1}
  .ba .was .n{font-size:clamp(26px,8vw,32px);color:var(--muted)}
  .ba .now .n{font-size:clamp(36px,11vw,44px);color:var(--accent)}
  .ba .arrow{font-family:var(--mono);font-size:26px;color:var(--muted2)}
  .ba .u{font-size:11px;color:var(--muted)}
  .drop{text-align:center;margin-top:10px;font-size:13px;color:var(--muted)}
  .drop b{color:var(--ok);font-weight:700}

  .note{font-size:14px;line-height:1.55;color:var(--muted)}
  .note b{color:var(--text);font-weight:600}
  .cta{display:block;text-align:center;margin-top:6px;background:var(--accent);color:#0B0E12;font-family:var(--sans);font-weight:600;font-size:16px;text-decoration:none;border-radius:12px;padding:16px 20px}
  .cta:hover{filter:brightness(1.05)}
  .cta-sub{font-size:13px;color:var(--muted2);text-align:center}
  .cta-sub b{color:var(--text)}
</style>

<script is:inline>
  (function () {
    var fmt = function (n) { return Math.round(n).toLocaleString('ru-RU').replace(/,/g, ' '); };
    var num = function (v) { return parseInt(String(v).replace(/[^\d]/g, ''), 10) || 0; };
    var ids = ['fixed', 'cur', 'ad', 'paid'], el = {};
    ids.forEach(function (i) { el[i] = document.getElementById(i); });
    if (!el.fixed) return;
    var cplNow = document.getElementById('cplNow'), cppaid = document.getElementById('cppaid'),
        wasEl = document.getElementById('was'), nowEl = document.getElementById('now'),
        dropText = document.getElementById('dropText'), dropv = document.getElementById('dropv');
    var anim = null;
    function animateTo(node, target) {
      if (anim) cancelAnimationFrame(anim);
      var start = num(node.textContent) || 0, t0 = performance.now(), d = 550;
      function step(t) { var p = Math.min(1, (t - t0) / d), e = 1 - Math.pow(1 - p, 3);
        node.textContent = fmt(start + (target - start) * e); if (p < 1) anim = requestAnimationFrame(step); }
      anim = requestAnimationFrame(step);
    }
    function recalc(animate) {
      var fixed = num(el.fixed.value), cur = num(el.cur.value), ad = num(el.ad.value), paid = num(el.paid.value);
      var now1 = cur > 0 ? fixed / cur : 0;
      var perPaid = paid > 0 ? ad / paid : 0;
      var blended = (cur + paid) > 0 ? (fixed + ad) / (cur + paid) : 0;
      cplNow.textContent = fmt(now1) + ' ₽';
      cppaid.textContent = fmt(perPaid) + ' ₽';
      wasEl.textContent = fmt(now1);
      var drop = now1 > 0 ? Math.round((1 - blended / now1) * 100) : 0;
      if (drop > 0) { dropText.textContent = 'дешевле на '; dropv.textContent = drop + '%'; }
      else { dropText.textContent = 'введите заказы с рекламы'; dropv.textContent = ''; }
      if (animate) animateTo(nowEl, blended); else nowEl.textContent = fmt(blended);
    }
    ids.forEach(function (i) {
      el[i].addEventListener('input', function () {
        var raw = String(el[i].value).replace(/[^\d]/g, '');
        el[i].value = raw ? fmt(parseInt(raw, 10)) : '';
        recalc(i === 'ad' || i === 'paid');
      });
      el[i].addEventListener('focus', function () { el[i].select(); });
    });
    recalc(false);
  })();
</script>
