---
import { site, operator } from '../data/site';
import { categories } from '../data/categories';
---
<footer class="site-footer">
  <div class="wrap">
    <div class="foot">
      <div>
        <a href="/" class="logo"><span class="br">[</span>{site.name}<span class="br">]</span></a>
        <p>{site.tagline}. Делаем сайты, продвигаем и приводим клиентов. По фикс-смете и точным срокам.</p>
      </div>
      <div>
        <h5>Услуги</h5>
        <ul>
          {categories.map((c) => <li><a href={`/uslugi#${c.slug}`}>{c.label}</a></li>)}
          <li><a href="/uslugi">Все услуги →</a></li>
        </ul>
      </div>
      <div>
        <h5>Контакты</h5>
        <ul>
          <li><a href="/#contact">Рассчитать проект</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href={site.phoneHref}>{site.phone}</a></li>
          <li><a href={site.telegram} rel="noopener" target="_blank">Telegram</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-legal">
      <span>{operator.name}. {operator.statusShort}. ИНН {operator.inn}</span>
      <a href="/privacy">Политика обработки персональных данных</a>
    </div>
    <div class="foot-bottom">
      <span>© {new Date().getFullYear()} {site.name}. Все права защищены.</span>
      <span>// digital-студия полного цикла</span>
    </div>
  </div>
</footer>
