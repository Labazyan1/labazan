---
// Липкая кнопка «Оставить заявку». Появляется после первого экрана и занимает
// освободившийся слот внизу слева (чат-бот — внизу справа, не сталкиваются).
// Инлайн-JS без зависимостей — ради статики Beget. Доступность: пока скрыта —
// убрана из tab-порядка и из дерева доступности; появилась — возвращается.
---
<div class="sticky-cta" aria-hidden="true">
  <a href="/#contact" class="btn btn-primary" tabindex="-1">Оставить заявку <span class="arrow">→</span></a>
</div>

<script is:inline>
  (function () {
    var el = document.querySelector('.sticky-cta');
    if (!el) return;
    var link = el.querySelector('a');
    function setShown(on) {
      el.classList.toggle('in', on);
      el.setAttribute('aria-hidden', on ? 'false' : 'true');
      if (link) link.tabIndex = on ? 0 : -1;
    }
    var hero = document.querySelector('.hero');
    // На главной показываем, когда первый экран (.hero) ушёл из вида.
    if ('IntersectionObserver' in window && hero) {
      var io = new IntersectionObserver(function (entries) {
        setShown(!entries[0].isIntersecting);
      }, { threshold: 0 });
      io.observe(hero);
    } else {
      // Внутренние страницы без .hero — показываем после прокрутки вниз.
      var onScroll = function () { setShown(window.scrollY > window.innerHeight * 0.8); };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  })();
</script>
